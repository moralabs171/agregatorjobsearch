# Скопируй этот файл в .env и заполни реальными значениями.

# Токен бота от @BotFather (обязательно)
TELEGRAM_BOT_TOKEN=

# Разрешённые chat_id через запятую (обязательно для приватного бота).
# Свой id можно узнать у @userinfobot. Пример: 123456789,987654321
ALLOWED_CHAT_IDS=

# Город поиска по умолчанию
DEFAULT_CITY=Chemnitz

# Радиус поиска в км вокруг города
DEFAULT_RADIUS_KM=25

# Период автопроверки подписок в минутах (по умолчанию раз в час)
POLL_INTERVAL_MINUTES=60

# За сколько последних дней искать обычные вакансии (0-100)
PUBLISHED_SINCE_DAYS=7

# За сколько последних дней искать Ausbildung (0-100).
# Места Ausbildung публикуют сильно заранее, поэтому окно шире.
AUSBILDUNG_SINCE_DAYS=100

# Тип занятости по умолчанию (необязательно, пусто = любая).
# Допустимо через пробел: vz tz ho mj snw
# vz=Vollzeit, tz=Teilzeit, ho=Homeoffice, mj=Minijob, snw=смена/ночь/выходные
DEFAULT_ARBEITSZEIT=

# Путь к файлу базы SQLite
DB_PATH=jobs.db
